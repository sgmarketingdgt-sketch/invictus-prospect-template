# =====================================================================
# Invictus Prospect Template — exemplo de configuração
# =====================================================================
# Copie este arquivo para `.env` e preencha as chaves.
# O `.env` está no `.gitignore` — nunca será commitado.
# =====================================================================

# ---------------------------------------------------------------------
# Identificação da rodada (obrigatório)
# ---------------------------------------------------------------------
# Quem está rodando o pipeline. Aparece no CRM e isola dados no Supabase
# se você usar a mesma conta para várias marcas.
AGENCIA="Sua Marca"

# Segmento e cidade da prospecção atual (informativo + chave de
# deduplicação no Supabase).
SEGMENTO="academias"
CIDADE="Belo Horizonte"

# ---------------------------------------------------------------------
# Google Places API (obrigatório para a Fase 01 de extração)
# ---------------------------------------------------------------------
# Crie em: https://console.cloud.google.com/apis/credentials
# Habilite a API "Places API (New)".
GOOGLE_PLACES_API_KEY=

# ---------------------------------------------------------------------
# Supabase (opcional, recomendado)
# ---------------------------------------------------------------------
# Crie um projeto grátis em https://supabase.com.
# Sem isto, o CRM funciona local via localStorage.
# Com isto, ganha sync entre dispositivos e modo incremental real.
#
# Onde encontrar (Project Settings > API):
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string para `setup_supabase.py` em modo automático.
# Project Settings > Database > Connection string > URI.
# Substitua [YOUR-PASSWORD] pela senha do banco.
SUPABASE_DB_URL=

# ---------------------------------------------------------------------
# Validação de WhatsApp (opcional)
# ---------------------------------------------------------------------
# Endpoint Evolution API para checar se um número é WhatsApp ativo.
# Veja docs: https://doc.evolution-api.com
# Se vazio, a Fase D registra apenas como "provável" baseado no DDD.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ---------------------------------------------------------------------
# Anthropic (opcional)
# ---------------------------------------------------------------------
# Usado se você quiser rodar enriquecimento via API direta. O fluxo
# default usa o próprio Claude Code, então normalmente não precisa.
ANTHROPIC_API_KEY=
