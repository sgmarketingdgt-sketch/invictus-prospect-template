EVOLUTION_API_URL=https://domesticram-evolution.cloudfy.live/manager
EVOLUTION_API_KEY=pBtkAe1IGt97Uday5hFOqKuGoAD1yaqI
EVOLUTION_INSTANCE=Teste API

