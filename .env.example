# Connection string para `setup_supabase.py` em modo automático.
# Project Settings > Database > Connection string > URI.
# Substitua [YOUR-PASSWORD] pela senha do banco.
SUPABASE_DB_URL=postgresql://postgres:[SGmidias;28]@db.blwkfqfcwlxnydliucrd.supabase.co:5432/postgres

# ---------------------------------------------------------------------
# Validação de WhatsApp (opcional)
# ---------------------------------------------------------------------
